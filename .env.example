# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy this to .env on your EC2 instance and fill in values.
#
# NEVER commit a real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_<your-supabase-secret-key>
SUPABASE_JWKS_URL=https://<your-project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running via docker-compose, ALWAYS use the service name "redis" as host.
# docker-compose.yml overrides this automatically, but keep it here for clarity.
REDIS_URL=redis://redis:6379

# ── URLs ─────────────────────────────────────────────────────────────────────
# Replace with your EC2 public domain / IP (or your custom domain if set up).
BASE_URL=https://yourdomain.com
FRONTEND_URL=https://your-frontend-domain.com
